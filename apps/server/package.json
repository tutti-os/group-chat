{
  "name": "@group-chat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "core:smoke": "node scripts/core-flow-smoke.mjs",
    "local-agent:smoke": "node scripts/local-agent-smoke.mjs",
    "workspace:smoke": "node scripts/workspace-smoke.mjs",
    "backfill:assistant-links": "tsx src/scripts/backfill-assistant-reference-links.ts --all",
    "backfill:assistant-links:dry-run": "tsx src/scripts/backfill-assistant-reference-links.ts --all --dry-run",
    "start": "node dist/apps/server/src/main.js"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@group-chat/shared": "workspace:*",
    "@tutti-os/agent-acp-kit": "0.2.2",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
